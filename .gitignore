# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ── Python / Backend ────────────────────────────────────────────────────────

# Virtual environment — NEVER commit this (contains symlinks that break Git on Windows)
BackEnd/venv/
venv/
.venv/

# Python cache files
__pycache__/
*.py[cod]
*.pyo

# Environment variables (contains secrets like DB passwords, API keys)
BackEnd/.env
.env

# Flask / SQLAlchemy database files
*.db
*.sqlite
*.sqlite3

# ── Memory Forensics Data ───────────────────────────────────────────────────

# Raw memory dump files — binary files, often gigabytes in size
*.mem
*.dmp
*.raw
*.vmem
*.lime

# Generated analysis reports (these are outputs, not source code)
BackEnd/data/cases/*/report.json

# Volatility symbol files
BackEnd/symbols/

# ── Misc ────────────────────────────────────────────────────────────────────

# Python egg / dist
*.egg-info/
dist/
