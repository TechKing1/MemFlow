@startuml Memory Forensics Class Diagram

!theme plain
skinparam classAttributeIconSize 0
skinparam backgroundColor #FFFFFF

title Memory Forensics Automation Tool - Class Diagram (Noun Technique)

' ============================================================================
' DOMAIN MODELS (Nouns from Requirements)
' ============================================================================

package "Domain Models" {
    
    class Case {
        - id: Integer {PK}
        - name: String
        - description: Text
        - status: String
        - priority: Integer
        - created_at: DateTime
        - updated_at: DateTime
        - metadata: JSON
        --
        + to_dict(): Dictionary
        + update_status(status: String): void
        + set_priority(priority: Integer): void
    }
    
    class CaseFile {
        - id: Integer {PK}
        - case_id: Integer {FK}
        - file_path: String
        - file_size: BigInteger
        - checksum: String
        - mime_type: String
        - stored_at: DateTime
        - report_path: String
        - notes: Text
        --
        + to_dict(): Dictionary
        + calculate_checksum(): String
        + verify_integrity(): Boolean
    }
    
    class AnalysisJob {
        - job_id: String {PK}
        - case_id: Integer {FK}
        - status: String
        - created_at: DateTime
        - started_at: DateTime
        - completed_at: DateTime
        - timeout: Integer
        - result_ttl: Integer
        - failure_ttl: Integer
        - error_message: String
        --
        + enqueue(): String
        + get_status(): String
        + mark_complete(): void
        + mark_failed(error: String): void
    }
    
    class AnalysisReport {
        - report_id: Integer {PK}
        - case_id: Integer {FK}
        - file_path: String
        - format: String
        - generated_at: DateTime
        - summary: JSON
        - findings: JSON
        - metadata: JSON
        --
        + generate(): void
        + export_json(): String
        + export_pdf(): String
        + get_summary(): Dictionary
    }
    
    class User {
        - user_id: Integer {PK}
        - username: String
        - email: String
        - role: String
        - created_at: DateTime
        - last_login: DateTime
        --
        + authenticate(): Boolean
        + has_permission(action: String): Boolean
    }
}

' ============================================================================
' ANALYSIS ENTITIES (Nouns from Analysis Domain)
' ============================================================================

package "Analysis Entities" {
    
    class MemoryDump {
        - file_path: String
        - file_size: BigInteger
        - format: String
        - os_type: String
        - checksum: String
        --
        + detect_format(): FormatInfo
        + detect_os(): OSInfo
        + validate(): Boolean
        + read_header(size: Integer): Bytes
    }
    
    class FormatInfo {
        - format_type: String
        - confidence: String
        - evidence: List<String>
        - magic_bytes: Bytes
        --
        + is_supported(): Boolean
        + get_confidence_score(): Float
    }
    
    class OSInfo {
        - os_type: String
        - os_version: String
        - architecture: String
        - confidence: String
        - evidence: List<String>
        --
        + get_plugin_profile(): String
        + is_windows(): Boolean
        + is_linux(): Boolean
    }
    
    class Process {
        - pid: Integer
        - name: String
        - parent_pid: Integer
        - command_line: String
        - start_time: DateTime
        - path: String
        --
        + is_suspicious(): Boolean
        + get_children(): List<Process>
    }
    
    class NetworkConnection {
        - protocol: String
        - local_address: String
        - local_port: Integer
        - remote_address: String
        - remote_port: Integer
        - state: String
        - pid: Integer
        --
        + is_external(): Boolean
        + get_process(): Process
    }
    
    class VolatilityPlugin {
        - name: String
        - category: String
        - os_type: String
        - description: String
        - timeout: Integer
        --
        + execute(dump_path: String): String
        + parse_output(output: String): Dictionary
        + is_applicable(os: String): Boolean
    }
    
    class AnalysisResult {
        - plugin_name: String
        - execution_time: Float
        - status: String
        - output: String
        - parsed_data: JSON
        - error: String
        --
        + is_successful(): Boolean
        + get_findings(): List<Finding>
    }
    
    class Finding {
        - finding_id: String
        - type: String
        - severity: String
        - description: String
        - evidence: JSON
        - timestamp: DateTime
        --
        + get_severity_level(): Integer
        + format_for_report(): Dictionary
    }
}

' ============================================================================
' SERVICE LAYER (Nouns representing services/handlers)
' ============================================================================

package "Services" {
    
    class FileHandler {
        - upload_dir: String
        - max_file_size: Integer
        --
        + save_file(file: File, case_id: Integer): String
        + validate_file(file: File): Boolean
        + calculate_checksum(file_path: String): String
        + create_case_directory(case_id: Integer): String
        + sanitize_filename(filename: String): String
    }
    
    class JobQueue {
        - redis_connection: Redis
        - queue_name: String
        --
        + enqueue(task: Function, args: Dictionary): String
        + get_job_status(job_id: String): String
        + get_job_result(job_id: String): Any
        + cancel_job(job_id: String): Boolean
    }
    
    class Worker {
        - queue: JobQueue
        - max_jobs: Integer
        - timeout: Integer
        --
        + start(): void
        + stop(): void
        + process_job(job: AnalysisJob): void
        + handle_failure(job: AnalysisJob, error: Exception): void
    }
    
    class FormatDetector {
        - signatures: Dictionary
        - sample_size: Integer
        --
        + detect_format(file_path: String): FormatInfo
        + check_magic_bytes(header: Bytes): String
        + calculate_confidence(evidence: List): String
    }
    
    class OSDetector {
        - windows_signatures: List<Bytes>
        - linux_signatures: List<Bytes>
        - macos_signatures: List<Bytes>
        --
        + detect_os(file_path: String): OSInfo
        + scan_for_signatures(sample: Bytes): Dictionary
        + calculate_confidence(matches: Dictionary): String
    }
    
    class PluginExecutor {
        - max_workers: Integer
        - timeout: Integer
        --
        + execute_plugins(plugins: List, dump_path: String): List<AnalysisResult>
        + execute_parallel(plugins: List): List<AnalysisResult>
        + parse_plugin_output(output: String, plugin: String): Dictionary
    }
    
    class ReportGenerator {
        - template_dir: String
        - output_format: String
        --
        + generate_report(case_id: Integer, results: List): AnalysisReport
        + create_json_report(data: Dictionary): String
        + create_pdf_report(data: Dictionary): String
        + create_summary(results: List): Dictionary
    }
    
    class CaseManager {
        - database: Database
        --
        + create_case(name: String, description: String): Case
        + get_case(case_id: Integer): Case
        + get_all_cases(page: Integer, limit: Integer): List<Case>
        + update_case_status(case_id: Integer, status: String): void
        + filter_cases(status: String): List<Case>
        + search_cases(query: String): List<Case>
    }
}

' ============================================================================
' INFRASTRUCTURE (Nouns from technical infrastructure)
' ============================================================================

package "Infrastructure" {
    
    class Database {
        - connection_string: String
        - pool_size: Integer
        --
        + connect(): Connection
        + execute_query(sql: String): ResultSet
        + begin_transaction(): Transaction
        + commit(): void
        + rollback(): void
    }
    
    class RedisClient {
        - host: String
        - port: Integer
        - db: Integer
        --
        + connect(): Connection
        + ping(): Boolean
        + set(key: String, value: Any): void
        + get(key: String): Any
    }
    
    class FileSystem {
        - base_path: String
        --
        + create_directory(path: String): void
        + save_file(path: String, content: Bytes): void
        + read_file(path: String): Bytes
        + delete_file(path: String): void
        + file_exists(path: String): Boolean
    }
    
    class Logger {
        - log_level: String
        - log_file: String
        --
        + info(message: String): void
        + error(message: String, exception: Exception): void
        + warning(message: String): void
        + debug(message: String): void
    }
    
    class Configuration {
        - database_url: String
        - redis_url: String
        - upload_dir: String
        - queue_name: String
        --
        + load_from_env(): void
        + get(key: String): Any
        + validate(): Boolean
    }
}

' ============================================================================
' API LAYER (Nouns from API/Controller domain)
' ============================================================================

package "API Layer" {
    
    class CaseController {
        - case_manager: CaseManager
        - file_handler: FileHandler
        - job_queue: JobQueue
        --
        + upload_case(request: Request): Response
        + get_all_cases(request: Request): Response
        + get_case_details(case_id: Integer): Response
        + get_case_status(case_id: Integer): Response
        + get_case_report(case_id: Integer): Response
    }
    
    class Request {
        - method: String
        - path: String
        - headers: Dictionary
        - body: Any
        - files: List<File>
        - params: Dictionary
        --
        + get_param(key: String): Any
        + get_file(key: String): File
        + validate(): Boolean
    }
    
    class Response {
        - status_code: Integer
        - headers: Dictionary
        - body: Any
        --
        + to_json(): String
        + set_header(key: String, value: String): void
    }
    
    class Validator {
        --
        + validate_file_extension(filename: String): Boolean
        + validate_case_name(name: String): Boolean
        + validate_priority(priority: Integer): Boolean
        + validate_pagination(page: Integer, limit: Integer): Boolean
    }
}

' ============================================================================
' UI LAYER (Nouns from Frontend domain)
' ============================================================================

package "UI Layer (Flutter)" {
    
    class DashboardScreen {
        - case_repository: CaseRepository
        --
        + load_statistics(): void
        + load_recent_cases(): void
        + navigate_to_upload(): void
        + refresh_data(): void
    }
    
    class UploadScreen {
        - selected_file: File
        - case_repository: CaseRepository
        --
        + select_file(): void
        + validate_file(): Boolean
        + upload_case(): void
        + show_progress(): void
    }
    
    class CaseRepository {
        - api_client: ApiClient
        --
        + upload_case(file: File, name: String): Case
        + get_cases(page: Integer, limit: Integer): List<Case>
        + get_case_status(case_id: Integer): String
        + get_case_report(case_id: Integer): AnalysisReport
    }
    
    class ApiClient {
        - base_url: String
        - timeout: Integer
        --
        + post(endpoint: String, data: Any): Response
        + get(endpoint: String, params: Dictionary): Response
        + upload_file(endpoint: String, file: File): Response
    }
}

' ============================================================================
' RELATIONSHIPS
' ============================================================================

' Domain Model Relationships
Case "1" *-- "many" CaseFile : contains
Case "1" -- "1" AnalysisJob : has
Case "1" -- "0..1" AnalysisReport : generates
User "1" -- "many" Case : creates

CaseFile "1" -- "1" MemoryDump : represents
AnalysisReport "1" *-- "many" Finding : contains

' Analysis Relationships
MemoryDump "1" -- "1" FormatInfo : has
MemoryDump "1" -- "1" OSInfo : has
AnalysisResult "1" -- "many" Process : extracts
AnalysisResult "1" -- "many" NetworkConnection : identifies
AnalysisResult "many" -- "1" VolatilityPlugin : produced by
AnalysisResult "1" *-- "many" Finding : generates

Process "1" -- "many" NetworkConnection : owns

' Service Layer Relationships
CaseManager ..> Database : uses
CaseManager ..> Case : manages
FileHandler ..> FileSystem : uses
FileHandler ..> CaseFile : creates

JobQueue ..> RedisClient : uses
JobQueue ..> AnalysisJob : manages
Worker ..> JobQueue : polls
Worker ..> PluginExecutor : uses

FormatDetector ..> MemoryDump : analyzes
OSDetector ..> MemoryDump : analyzes
PluginExecutor ..> VolatilityPlugin : executes
PluginExecutor ..> AnalysisResult : produces

ReportGenerator ..> AnalysisReport : creates
ReportGenerator ..> AnalysisResult : consumes
ReportGenerator ..> FileSystem : uses

' API Layer Relationships
CaseController ..> CaseManager : uses
CaseController ..> FileHandler : uses
CaseController ..> JobQueue : uses
CaseController ..> Request : receives
CaseController ..> Response : returns
CaseController ..> Validator : uses

' UI Layer Relationships
DashboardScreen ..> CaseRepository : uses
UploadScreen ..> CaseRepository : uses
CaseRepository ..> ApiClient : uses
ApiClient ..> CaseController : calls

' Infrastructure Relationships
Logger ..> FileSystem : uses
Configuration ..> Logger : uses

' Cross-layer Dependencies
Worker ..> FormatDetector : uses
Worker ..> OSDetector : uses
Worker ..> ReportGenerator : uses
Worker ..> Database : updates

note top of Case
    Core domain entity representing
    a forensic investigation case
end note

note top of MemoryDump
    Represents the actual memory
    dump file being analyzed
end note

note top of VolatilityPlugin
    Encapsulates Volatility3
    plugin execution logic
end note

note top of JobQueue
    Manages asynchronous job
    processing via Redis Queue
end note

note bottom of CaseController
    REST API endpoint handler
    for case operations
end note

@enduml
